<script lang="ts">
  import { authUser, authToken } from '../lib/auth'
  import { goto } from 'astro:transitions/client'

  let name = ''
  let location = ''
  let startDate = ''
  let endDate = ''
  let loading = false
  let error = ''
  let success = false

  let user: any

  authUser.subscribe(value => {
    user = value
    if (!value || value.userType !== 'TOURNAMENT_DIRECTOR') {
      // Redirect if not authorized
      goto('/register')
    }
  })

  let token: string | null = null
  authToken.subscribe(value => {
    token = value
  })

  async function handleCreateTournament() {
    loading = true
    error = ''

    if (!token) {
      error = 'Not authenticated'
      loading = false
      return
    }

    try {
      const response = await fetch('http://localhost:4000/tournaments', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({
          name,
          location,
          startDate: new Date(startDate).toISOString(),
          endDate: endDate ? new Date(endDate).toISOString() : null
        })
      })

      if (!response.ok) {
        const errorData = await response.json()
        throw new Error(errorData.error || 'Failed to create tournament')
      }

      const tournamentData = await response.json()
      success = true

      setTimeout(() => {
        goto(`/tournaments/${tournamentData.id}`)
      }, 1000)
    } catch (err: any) {
      error = err.message || 'An error occurred'
    } finally {
      loading = false
    }
  }
</script>

<main class="tournament-container">
  <div class="tournament-card">
    <div class="header">
      <h1>Create New Tournament</h1>
      <p>Set up a new tournament for your event</p>
    </div>

    {#if success}
      <div class="success-message">
        ✓ Tournament created successfully! Redirecting...
      </div>
    {:else}
      <form on:submit|preventDefault={handleCreateTournament}>
        <div class="form-group">
          <label for="name">Tournament Name *</label>
          <input
            type="text"
            id="name"
            bind:value={name}
            required
            placeholder="e.g., Summer Championships 2026"
            disabled={loading}
          />
        </div>

        <div class="form-group">
          <label for="location">Location</label>
          <input
            type="text"
            id="location"
            bind:value={location}
            placeholder="e.g., Central Park, New York"
            disabled={loading}
          />
        </div>

        <div class="date-row">
          <div class="form-group">
            <label for="startDate">Start Date *</label>
            <input
              type="date"
              id="startDate"
              bind:value={startDate}
              required
              disabled={loading}
            />
          </div>

          <div class="form-group">
            <label for="endDate">End Date</label>
            <input
              type="date"
              id="endDate"
              bind:value={endDate}
              disabled={loading}
            />
          </div>
        </div>

        {#if error}
          <div class="error-message">
            ✗ {error}
          </div>
        {/if}

        <button type="submit" disabled={loading}>
          {loading ? 'Creating Tournament...' : 'Create Tournament'}
        </button>

        <p class="back-link">
          <a href="/dashboard">Back to Dashboard</a>
        </p>
      </form>
    {/if}
  </div>
</main>

